.github/

# Build directories
/build*
/build_

# CMake generated files
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Makefile
install_manifest.txt
compile_commands.json

# Ninja
.ninja_deps
.ninja_log
*.ninja

# Visual Studio / IDE
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.VC.db
*.VC.VC.opendb
*.vcxproj.user
*.vcxproj.filters
*.sln

# Compiled objects and binaries
*.obj
*.o
*.lib
*.a
*.so
*.dll
*.exe
*.pdb

# Logs, temporary files
*.log
logs/
*.tmp
*~
*.swp

# OS files
.DS_Store
Thumbs.db

# Coverage / profiling
*.gcda
*.gcno
*.prof

# Test artifacts
test-output/

# Database files and runtime state
/data/
data/
*.db

# Certificates and private keys (do NOT commit private keys)
certs/*.key
certs/*.pfx
certs/*.pem
certs/*.crt

# Secrets and credentials
*.env
secrets/

# Generated single-file third-party artifacts (if built at repo root)
*.zip
*.tar.gz

# Keep source, headers, CMakeLists.txt, CMakePresets.json, docs, scripts, and vendored third_party
# (Do not ignore src/ or src/third_party unless you explicitly want to exclude a vendored library)

# Exclude documentation from commits
docs/
